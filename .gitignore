# ==================================================
#  .gitignore — SaasCaldas-Brito 2.0
#  NUNCA commitar chaves, segredos ou dependências
# ==================================================

# ── Variáveis de ambiente (NUNCA commitar) ─────────
.env
.env.*
.env.local
.env.*.local
backend/.env
frontend/.env
*.env

# ── Chaves e segredos explícitos ─────────────────
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets.*
credentials.*

# ── Supabase env local ────────────────────────────
js/env.js
frontend/js/env.js

# ── Node / dependências ───────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
.npm

# ── Build / dist ──────────────────────────────────
dist/
build/
.next/
out/

# ── Logs ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/

# ── Artefatos de assistentes de IA ───────────────
*.bak
*.bak_blackboxai
*.bak_blackboxai.*
*.bak_cursor
*.orig

# ── OS / Editor ───────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Vercel / Railway ──────────────────────────────
.vercel
.railway

# ── Cache e temporários ───────────────────────────
.cache/
.parcel-cache/
tmp/
temp/

