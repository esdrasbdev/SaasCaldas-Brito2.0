{
  "version": 2,
  "name": "juridico-caldas-brito",
  "installCommand": "npm install --prefix backend",
  "rewrites": [


    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/publicacoes/sincronizar",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/alertas/cron",
      "schedule": "0 7 * * *"
    }
  ]
}
